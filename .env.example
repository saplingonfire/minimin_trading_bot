# Roostoo API (required)
ROOSTOO_API_KEY=your_api_key_here
ROOSTOO_SECRET_KEY=your_secret_key_here

# Optional: default https://mock-api.roostoo.com
# ROOSTOO_BASE_URL=https://mock-api.roostoo.com

# Bot
BOT_STRATEGY=example
BOT_TICK_SECONDS=30
BOT_DRY_RUN=false
BOT_CANCEL_ORDERS_ON_STOP=false

# Optional: strategy params as JSON
# BOT_STRATEGY_PARAMS={"pair":"BTC/USD","size":0.001,"every_n_ticks":10}

# Optional: risk guards
# BOT_MAX_PENDING_ORDERS=10
# BOT_MAX_ORDER_NOTIONAL=10000
