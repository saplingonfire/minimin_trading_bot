# Live account (used when BOT_LIVE=true or --live)
ROOSTOO_API_KEY=your_live_api_key_here
ROOSTOO_SECRET_KEY=your_live_secret_key_here
# ROOSTOO_BASE_URL=https://api.roostoo.com

# Test account (used when BOT_LIVE=false or --test, default)
ROOSTOO_TEST_API_KEY=your_test_api_key_here
ROOSTOO_TEST_SECRET_KEY=your_test_secret_key_here
# ROOSTOO_TEST_BASE_URL=https://mock-api.roostoo.com

# Bot (default: test account)
BOT_STRATEGY=example
BOT_LIVE=false
BOT_TICK_SECONDS=30
BOT_DRY_RUN=false
BOT_CANCEL_ORDERS_ON_STOP=false

# Optional: strategy params as JSON
# BOT_STRATEGY_PARAMS={"pair":"BTC/USD","size":0.001,"every_n_ticks":10}

# Optional: risk guards
# BOT_MAX_PENDING_ORDERS=10
# BOT_MAX_ORDER_NOTIONAL=10000

# Optional: OHLCV data dir for strategies that use historical candles (e.g. momentum, Bollinger/RSI)
# BINANCE_DATA_DIR=data/binance
