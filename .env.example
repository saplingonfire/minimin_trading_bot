# Live account (used when BOT_LIVE=true or --live)
ROOSTOO_API_KEY=your_live_api_key_here
ROOSTOO_SECRET_KEY=your_live_secret_key_here
# ROOSTOO_BASE_URL=https://api.roostoo.com

# Test account (used when BOT_LIVE=false or --test, default)
ROOSTOO_TEST_API_KEY=your_test_api_key_here
ROOSTOO_TEST_SECRET_KEY=your_test_secret_key_here
# ROOSTOO_TEST_BASE_URL=https://mock-api.roostoo.com

# Bot (default: test account)
BOT_STRATEGY=hybrid_trend_cross_sectional
BOT_LIVE=false

# Dashboard: use live credentials when true (default: false = test account)
DASHBOARD_USE_LIVE=false
BOT_TICK_SECONDS=30
BOT_DRY_RUN=false
BOT_CANCEL_ORDERS_ON_STOP=false

# Optional: strategy params as JSON (or use config.yaml)
# BOT_STRATEGY_PARAMS={"pair":"BTC/USD","size":0.001,"every_n_ticks":10}

# --- Hybrid Trend + Cross-Sectional Momentum (BOT_STRATEGY=hybrid_trend_cross_sectional) ---
# Optional env (override config.yaml / defaults):
# BOT_TICK_SECONDS=300
# BOT_PRICE_STORE_PATH=prices.db
# BOT_MAX_ORDERS_PER_CYCLE=2
# BOT_ORDER_SPACING_SEC=65
# BOT_CONFIG_PATH=config.yaml
# Optional strategy params (JSON) for hybrid:
# BOT_STRATEGY_PARAMS={"N":5,"ma_window":20,"target_exposure":0.85,"max_weight_per_coin":0.2,"min_trade_usd":50,"min_volume_usd":500000,"rank_interval_min":60,"max_orders_per_cycle":2,"order_spacing_sec":65,"db_path":"prices.db","risk":{"max_consecutive_errors":5,"btc_daily_move_kill":0.4}}

# --- Hybrid Throttled (BOT_STRATEGY=hybrid_trend_cross_sectional_throttled, prelim soft exposure) ---
# BOT_STRATEGY=hybrid_trend_cross_sectional_throttled
# Optional regime params (or use config.yaml strategy.regime): prelim_mode, strong_exposure, soft_exposure, consecutive_below_to_off
# BOT_STRATEGY_PARAMS={"N":5,"ma_window":20,"regime":{"prelim_mode":true,"strong_exposure":0.85,"soft_exposure":0.35,"consecutive_below_to_off":2},"db_path":"prices.db"}

# Example params for other strategies (set BINANCE_DATA_DIR and sync data first):
# Cross-Sectional Momentum: BOT_STRATEGY=cross_sectional_momentum BOT_STRATEGY_PARAMS={"rebalance_days":7,"top_n":5,"max_weight_per_coin":0.2}
# Momentum 20/50:          BOT_STRATEGY=momentum_20_50 BOT_STRATEGY_PARAMS={"pair":"BTC/USD","interval":"4h","atr_mult":2}
# Bollinger/RSI:          BOT_STRATEGY=bollinger_rsi BOT_STRATEGY_PARAMS={"pair":"ETH/USD","risk_amount":100,"rsi_oversold":30}

# Optional: risk guards
# BOT_MAX_PENDING_ORDERS=10
# BOT_MAX_ORDER_NOTIONAL=10000

# Optional: OHLCV data dir for strategies that use historical candles (e.g. momentum, Bollinger/RSI)
# BINANCE_DATA_DIR=data/binance
